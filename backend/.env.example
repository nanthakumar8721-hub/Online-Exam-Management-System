# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/exam-monitoring-system

# Authentication Configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRE=24h

# SMTP / Email Configuration (Example for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER must be your full Gmail address
SMTP_USER=your-email@gmail.com
# SMTP_PASS must be a 16-character App Password, not your regular password
SMTP_PASS=abcd efgh ijkl mnop
FROM_EMAIL=noreply@examsystem.com
FROM_NAME=ExamSystemAdmin

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
